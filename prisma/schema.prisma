generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String       @id @default(uuid())
  email                 String       @unique
  password              String
  slug                  String       @unique
  displayName           String       @default("")
  stripeAccountId       String?
  stripeOnboarded       Boolean      @default(false)
  resetToken            String?
  resetTokenExpiry      DateTime?
  queueCoinCost         Int          @default(1)
  queueJumpCost         Int          @default(5)
  maxJumpsPerSession    Int          @default(2)
  playNextCost          Int          @default(15)
  maxPlayNextPerSession Int          @default(1)
  shoutoutCost          Int          @default(10)
  createdAt             DateTime     @default(now())
  songs                 Song[]
  queue                 QueueItem[]
  shoutouts             Shoutout[]
  tokenGrants           TokenGrant[]
}

model Song {
  id        String   @id @default(uuid())
  title     String
  artist    String   @default("")
  genre     String   @default("Other")
  active    Boolean  @default(true)
  order     Int      @default(0)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model QueueItem {
  id         String   @id @default(uuid())
  songTitle  String
  artist     String   @default("")
  genre      String   @default("Other")
  requester  String   @default("Anonymous")
  dedication String?
  tier       String   @default("STANDARD")
  priority   Boolean  @default(false)
  tokens     Int      @default(1)
  played     Boolean  @default(false)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}

model Shoutout {
  id        String   @id @default(uuid())
  message   String
  fromName  String   @default("Anonymous")
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model TokenPackage {
  id          String   @id @default(uuid())
  name        String
  coins       Int
  price       Int
  description String   @default("")
  createdAt   DateTime @default(now())
}

model TokenGrant {
  id              String   @id @default(uuid())
  stripeSessionId String   @unique
  tokens          Int
  slug            String
  redeemed        Boolean  @default(false)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
